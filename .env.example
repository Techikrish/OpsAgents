# ── LLM Provider API Keys ────────────────────────────────────────────
# Set the API key for your chosen provider(s)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# ── AWS Credentials ──────────────────────────────────────────────────
# Option 1: Use AWS profile (recommended)
AWS_PROFILE=default
AWS_DEFAULT_REGION=us-east-1

# Option 2: Use access keys (not recommended for production)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ── Kubernetes ───────────────────────────────────────────────────────
# KUBECONFIG=~/.kube/config

# ── GitHub ───────────────────────────────────────────────────────────
# Required for CI/CD Pipeline Agent
# GITHUB_TOKEN=ghp_...

# ── Monitoring ───────────────────────────────────────────────────────
# GRAFANA_URL=http://localhost:3000
# GRAFANA_API_KEY=...
# PROMETHEUS_URL=http://localhost:9090

# ── OpsAgents Settings ──────────────────────────────────────────────
OPSAGENTS_CONFIG=config.yml
OPSAGENTS_LOG_LEVEL=INFO
